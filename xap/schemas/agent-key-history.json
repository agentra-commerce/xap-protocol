{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xap-protocol.org/schemas/agent-key-history.json",
  "title": "AgentKeyHistory",
  "description": "Append-only record of an agent's Ed25519 key history. Enables verification of receipts signed by historical keys.",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_id", "keys"],
  "properties": {
    "agent_id": {
      "type": "string",
      "pattern": "^agnt_[0-9a-zA-Z]{8,64}$"
    },
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key_id", "public_key", "active_from"],
        "properties": {
          "key_id": {
            "type": "string",
            "pattern": "^key_[0-9a-f]{8}$"
          },
          "public_key": {
            "type": "string",
            "minLength": 32,
            "maxLength": 128,
            "description": "Base64url Ed25519 public key"
          },
          "active_from": {
            "type": "string",
            "format": "date-time"
          },
          "active_until": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Null means currently active. Only one key may have null active_until per agent."
          },
          "rotation_reason": {
            "type": "string",
            "enum": ["initial", "scheduled", "compromise", "migration"],
            "description": "Why this key was created"
          },
          "successor_key_id": {
            "type": ["string", "null"],
            "pattern": "^key_[0-9a-f]{8}$",
            "description": "The key that replaced this one. Null if currently active."
          },
          "self_signature": {
            "type": "string",
            "description": "New key signs over: predecessor_key_id + active_until. Proves rotation was authorized."
          }
        }
      }
    }
  }
}
