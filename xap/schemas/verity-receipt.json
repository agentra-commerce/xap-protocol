{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xap.agentralabs.tech/schemas/v0.2/verity-receipt.json",
  "title": "VerityReceipt",
  "description": "XAP v0.2 — Deterministic decision provenance and replay. The truth engine primitive.",
  "type": "object",
  "required": [
    "verity_id",
    "settlement_id",
    "decision_type",
    "decision_timestamp",
    "input_state",
    "rules_applied",
    "computation",
    "outcome",
    "replay_hash",
    "confidence_bps",
    "chain_position",
    "xap_version",
    "verity_engine_version",
    "verity_signature"
  ],
  "additionalProperties": false,
  "properties": {
    "verity_id": {
      "type": "string",
      "pattern": "^vrt_[a-f0-9]{8}$",
      "description": "Unique Verity receipt identifier."
    },
    "settlement_id": {
      "type": "string",
      "pattern": "^stl_[a-f0-9]{8}$",
      "description": "The settlement this decision belongs to."
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^rcpt_[a-f0-9]{8}$",
      "description": "The ExecutionReceipt that references this Verity (linked after receipt issuance)."
    },
    "decision_type": {
      "type": "string",
      "enum": [
        "condition_verification",
        "split_calculation",
        "timeout_resolution",
        "dispute_initiation",
        "dispute_resolution",
        "reversal_execution",
        "reputation_update"
      ],
      "description": "What kind of decision this records."
    },
    "decision_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Exact moment the decision was made (ISO 8601)."
    },
    "input_state": {
      "$ref": "#/$defs/InputState"
    },
    "rules_applied": {
      "$ref": "#/$defs/RulesApplied"
    },
    "computation": {
      "$ref": "#/$defs/Computation"
    },
    "outcome": {
      "$ref": "#/$defs/Outcome"
    },
    "replay_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of (input_state + rules_applied + computation). Any party can recompute to verify integrity."
    },
    "confidence_bps": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000,
      "description": "How deterministic the decision was. 10000 = fully deterministic. Below 10000 = some probabilistic element."
    },
    "chain_previous_verity_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Hash of the previous VerityReceipt in this settlement's verity chain."
    },
    "chain_position": {
      "type": "integer",
      "minimum": 1,
      "description": "Position in this settlement's verity chain."
    },
    "xap_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Protocol version (semver)."
    },
    "verity_engine_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Engine version that produced this decision (semver)."
    },
    "verity_signature": {
      "type": "string",
      "pattern": "^ed25519:.+$",
      "description": "Engine's Ed25519 signature attesting to this capture."
    },
    "timestamp_authority": {
      "type": "object",
      "description": "RFC 3161 timestamp token from an independent TSA. Proves the receipt existed at tsa_timestamp regardless of ZexRail's clock.",
      "additionalProperties": false,
      "required": ["tsa_serial", "tsa_issuer", "tsa_timestamp", "tsa_token_hash"],
      "properties": {
        "tsa_serial": {
          "type": "string",
          "description": "Serial number of the TSA certificate that issued this token",
          "maxLength": 64
        },
        "tsa_issuer": {
          "type": "string",
          "description": "Distinguished name of the Timestamp Authority",
          "maxLength": 256
        },
        "tsa_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "UTC timestamp as recorded by the TSA — independent of ZexRail clock"
        },
        "tsa_token_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$",
          "description": "SHA-256 of the DER-encoded RFC 3161 timestamp token. Token stored in Evidence Ledger."
        }
      }
    },
    "key_id": {
      "type": "string",
      "pattern": "^key_[0-9a-f]{8}$",
      "description": "ID of the specific Ed25519 key that signed this receipt. Enables historical key lookup for receipts signed before a key rotation."
    },
    "causality": {
      "type": "object",
      "description": "Links this receipt to its position in a multi-agent workflow causal chain.",
      "additionalProperties": false,
      "required": ["workflow_id", "depth"],
      "properties": {
        "caused_by_receipt_id": {
          "type": "string",
          "pattern": "^vrt_[0-9a-f]{64}$",
          "description": "The VerityReceipt that triggered this settlement. Null for root receipts."
        },
        "workflow_id": {
          "type": "string",
          "pattern": "^wf_[0-9a-f]{8}$",
          "description": "Groups all receipts that are part of one multi-agent workflow."
        },
        "depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "0 = root (initiated by human or external trigger). N = Nth step in causal chain."
        }
      }
    }
  },
  "$defs": {
    "InputState": {
      "type": "object",
      "required": ["settlement_state", "contract_terms", "agent_states"],
      "additionalProperties": false,
      "description": "Complete inputs available at decision time.",
      "properties": {
        "settlement_state": {
          "type": "string",
          "description": "Settlement state at decision time (from settlement state machine)."
        },
        "contract_terms": {
          "type": "object",
          "required": ["pricing", "sla", "conditions"],
          "additionalProperties": false,
          "properties": {
            "pricing": {
              "type": "object",
              "description": "The agreed pricing."
            },
            "sla": {
              "type": "object",
              "description": "The agreed SLA."
            },
            "conditions": {
              "type": "array",
              "items": { "type": "object" },
              "description": "The declared conditions."
            }
          }
        },
        "agent_states": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/AgentState" },
          "description": "State of each agent involved."
        },
        "condition_values": {
          "type": "array",
          "items": { "$ref": "#/$defs/ConditionValue" },
          "description": "Measured values for each condition (for condition_verification)."
        },
        "elapsed_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Time elapsed since execution started (for timeout decisions)."
        },
        "dispute_evidence": {
          "$ref": "#/$defs/DisputeEvidence"
        }
      }
    },
    "AgentState": {
      "type": "object",
      "required": ["agent_id", "role"],
      "additionalProperties": false,
      "properties": {
        "agent_id": {
          "type": "string",
          "description": "Agent identifier."
        },
        "role": {
          "type": "string",
          "description": "Agent's role in this settlement."
        },
        "reputation_at_decision": {
          "type": "object",
          "description": "Agent's reputation snapshot at decision time."
        }
      }
    },
    "ConditionValue": {
      "type": "object",
      "required": ["condition_id"],
      "additionalProperties": false,
      "properties": {
        "condition_id": {
          "type": "string",
          "description": "Which condition."
        },
        "measured_value": {
          "type": "integer",
          "description": "What was actually measured."
        },
        "measurement_source": {
          "type": "string",
          "description": "Where the measurement came from."
        },
        "measurement_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When measured."
        },
        "verifier_attestation": {
          "type": "object",
          "description": "Cryptographic attestation from the external verifier for probabilistic conditions. Absent for deterministic conditions.",
          "additionalProperties": false,
          "required": ["verifier_id", "verifier_public_key", "signed_at", "payload_hash", "signature"],
          "properties": {
            "verifier_id": {
              "type": "string",
              "maxLength": 128,
              "description": "ID of the external verifier agent or service"
            },
            "verifier_public_key": {
              "type": "string",
              "minLength": 32,
              "maxLength": 128,
              "description": "Base64url Ed25519 public key of the external verifier"
            },
            "signed_at": {
              "type": "string",
              "format": "date-time"
            },
            "payload_hash": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$",
              "description": "SHA-256 of canonical_json(condition_id + result + confidence_bps + signed_at)"
            },
            "signature": {
              "type": "string",
              "minLength": 32,
              "maxLength": 256,
              "description": "Base64url Ed25519 signature over payload_hash"
            }
          }
        }
      }
    },
    "DisputeEvidence": {
      "type": "object",
      "additionalProperties": false,
      "description": "Evidence submitted (for dispute decisions).",
      "properties": {
        "submitted_by": {
          "type": "string",
          "description": "Agent who submitted."
        },
        "evidence_type": {
          "type": "string",
          "description": "Type of evidence."
        },
        "evidence_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Hash of evidence payload."
        }
      }
    },
    "RulesApplied": {
      "type": "object",
      "required": ["rules_version", "rules_hash", "applicable_rules"],
      "additionalProperties": false,
      "description": "Which rules governed this decision.",
      "properties": {
        "rules_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Version of the rules set (semver)."
        },
        "rules_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Hash of the complete rules set (for tamper evidence)."
        },
        "applicable_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ApplicableRule" },
          "description": "Which specific rules were evaluated."
        },
        "policy_overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/PolicyOverride" },
          "description": "Any policy overrides active."
        },
        "policy_content_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$",
          "description": "SHA-256 of the canonical JSON of the policy document that governed this decision. Independently verifiable at GET /xap/v1/policies/{policy_version}."
        },
        "policy_url": {
          "type": "string",
          "format": "uri",
          "description": "URL where the policy document can be retrieved and its hash verified.",
          "maxLength": 256
        }
      }
    },
    "ApplicableRule": {
      "type": "object",
      "required": ["rule_id", "rule_description", "evaluated"],
      "additionalProperties": false,
      "properties": {
        "rule_id": {
          "type": "string",
          "description": "Unique rule identifier."
        },
        "rule_description": {
          "type": "string",
          "maxLength": 500,
          "description": "Human-readable description of what this rule does."
        },
        "evaluated": {
          "type": "boolean",
          "description": "Was this rule evaluated."
        },
        "result": {
          "type": "string",
          "enum": ["pass", "fail", "skip", "not_applicable"],
          "description": "Rule evaluation result."
        }
      }
    },
    "PolicyOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["org", "team", "agent", "contract"],
          "description": "Where the override came from."
        },
        "override_description": {
          "type": "string",
          "description": "What was overridden."
        }
      }
    },
    "Computation": {
      "type": "object",
      "required": ["steps", "total_steps", "computation_duration_ms"],
      "additionalProperties": false,
      "description": "Step-by-step record of how the decision was made.",
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ComputationStep" },
          "description": "Ordered sequence of computation steps."
        },
        "total_steps": {
          "type": "integer",
          "minimum": 1,
          "description": "Total number of steps."
        },
        "computation_duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "How long the computation took."
        }
      }
    },
    "ComputationStep": {
      "type": "object",
      "required": ["step_number", "operation", "inputs", "output", "deterministic"],
      "additionalProperties": false,
      "properties": {
        "step_number": {
          "type": "integer",
          "minimum": 1,
          "description": "Step order."
        },
        "operation": {
          "type": "string",
          "description": "What operation was performed."
        },
        "inputs": {
          "type": "object",
          "description": "What data this step consumed."
        },
        "rule_applied": {
          "type": "string",
          "description": "Which rule governed this step."
        },
        "output": {
          "type": "object",
          "description": "What this step produced."
        },
        "deterministic": {
          "type": "boolean",
          "description": "Was this step fully deterministic."
        },
        "notes": {
          "type": "string",
          "maxLength": 500,
          "description": "Optional explanation."
        }
      }
    },
    "Outcome": {
      "type": "object",
      "required": ["decision", "settlement_state_after", "outcome_classification"],
      "additionalProperties": false,
      "description": "What was decided.",
      "properties": {
        "decision": {
          "type": "string",
          "description": "The decision that was made (e.g., release_funds, refund_full, apply_pro_rata)."
        },
        "settlement_state_after": {
          "type": "string",
          "description": "Settlement state after this decision."
        },
        "outcome_classification": {
          "type": "string",
          "enum": ["SUCCESS", "FAIL", "UNKNOWN", "DISPUTED", "REVERSED", "TIMEOUT", "PARTIAL"],
          "description": "Verity outcome classification."
        },
        "amounts_affected": {
          "type": "array",
          "items": { "$ref": "#/$defs/AmountAffected" },
          "description": "Any monetary amounts changed by this decision."
        },
        "reputation_effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/ReputationEffect" },
          "description": "Reputation changes resulting from this decision."
        },
        "requires_human_review": {
          "type": "boolean",
          "description": "Did this decision flag for human review."
        },
        "human_review_reason": {
          "type": "string",
          "description": "Why human review was flagged."
        }
      }
    },
    "AmountAffected": {
      "type": "object",
      "required": ["agent_id", "amount_minor_units", "direction"],
      "additionalProperties": false,
      "properties": {
        "agent_id": {
          "type": "string",
          "description": "Which agent."
        },
        "amount_minor_units": {
          "type": "integer",
          "description": "Amount in minor units."
        },
        "direction": {
          "type": "string",
          "enum": ["credit", "debit", "hold", "release"],
          "description": "Direction of the amount change."
        }
      }
    },
    "ReputationEffect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent_id": {
          "type": "string",
          "description": "Which agent."
        },
        "effect": {
          "type": "string",
          "description": "The effect on reputation."
        },
        "reason": {
          "type": "string",
          "description": "Why this effect was applied."
        }
      }
    }
  }
}
